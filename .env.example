# MongoDB Atlas connection string
MONGODB=

# JWT signing secret (use >=32 random bytes, e.g. `openssl rand -base64 48`)
JWT_SECRET=
JWT_EXPIRES_IN=7d

# Cohere AI API key (for goal plan generation)
COHERE_API_KEY=

# Cloudinary (for post image uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Optional: port override (default 3000)
# PORT=3000
